---
import BaseLayout from "../layouts/BaseLayout.astro";
import DownloadButton from "../components/DownloadButton.astro";
import CalScheduleButton from "../components/CalScheduleButton.astro";



const pageTitle = "About Me";

---


<BaseLayout pageTitle={pageTitle}>
    <p>I am about to complete my Master's in AI at Vrije Universiteit</p>
    <p>📍 I live in Amsterdam, but I grew up in Milan.</p>
    <p><em>Recently</em> I have been working on my <a href="/projects/master-thesis">Thesis</a>.</p>

    <p>
    I am now looking for a research position.
    My <strong>research interests</strong> lie in theoretical machine learning, world models, cognitive science, causal inference, explainability, reinforcement learning, algorithmic information theory and math as a whole.
    </p>
    <br></br>

    <DownloadButton href="/CV_Vannucci_Michele.pdf" filename="CV_Michele_Vannucci.pdf" text="Download My CV" />

    <h2>Contacts</h2>
    Below you can always find different ways to reach me.
    Otherwise, you can also schedule a free 30-minute meeting directly.
    
      <CalScheduleButton text="Schedule a call" link="michele-vannucci-ijafga/30min" ns="30min" layout="month_view" />
</BaseLayout>
